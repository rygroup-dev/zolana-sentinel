ZOLANA_HAR_PATH=/root/zolana/play.zolana.gg.har
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ZOLANA_TOKEN_MINT=Ez6gPDiNK7VtGe5o9vnhDHJq9QPHvEYmSo8teu8mpump
# Game treasury for on-chain $ZOLANA purchases (gacha/market use the server quote;
# /buystamina transfers here directly). Default = the game's canonical zolanaTreasury.
ZOLANA_TREASURY=Auywa2xpfcTaBmfzNCLXSLTM5kzBh9kwjuABHY2usVNC
# /buystamina cost in whole $ZOLANA → refills stamina to full (manual, confirm-gated).
ZOLANA_STAMINA_ZENKO_COST=50
# Auto-buy stamina with $ZOLANA when drained so raids resume immediately instead of
# waiting ~22h for regen. OFF by default (spends token). Daily cap bounds max spend.
# Toggle live via /toggle autostamina or the AutoStam button in /auto.
ZOLANA_AUTO_STAMINA=false
ZOLANA_AUTO_STAMINA_MAX_PER_DAY=4
ZOLANA_AUTO_MARKET=true
ZOLANA_AUTO_MARKET_BUY=true
ZOLANA_AUTO_MARKET_SELL=true
ZOLANA_MARKET_MAX_BUY_USD=1.1
ZOLANA_MARKET_MAX_BUYS_PER_CYCLE=1
ZOLANA_MARKET_MIN_EDGE_BPS=1800
ZOLANA_MARKET_ZOLANA_RESERVE=10000
ZOLANA_MARKET_CYCLE_BUDGET_ZOLANA=35000
ZOLANA_MARKET_SELL_LEVEL=5
ZOLANA_MARKET_KEEP_CREATURES=3
ZOLANA_MARKET_KEEP_GOLD=25000
ZOLANA_MARKET_BUY_KINDS=egg,creature
ZOLANA_MARKET_SELL_UNDERCUT=0.97
ZOLANA_MARKET_MIN_SELL_USD=0.05
ZOLANA_WITHDRAW_MIN_SOL_RESERVE=0.01
ZOLANA_MAX_WITHDRAW_SOL=0.25
ZOLANA_MARKET_SELL_LEVEL=8
# Autopilot modules (also toggleable live via Telegram /auto)
ZOLANA_AUTO_AFK=true
ZOLANA_AUTO_CLAIMS=true
ZOLANA_AUTO_QUESTS=true
ZOLANA_AUTO_DUNGEON=true
# Stamina-cycle raiding: when stamina is full, RAID with the STRONGEST creatures
# (unplaced from the farm) in parallel bursts that climb to the highest floor their
# detected power can clear, draining stamina; then FARM the strongest for gold while
# stamina regenerates; re-raid once refilled. false = legacy "farm strongest, raid rest".
ZOLANA_RAID_STAMINA_CYCLE=true
ZOLANA_RAID_REFILL_FRAC=0.9
ZOLANA_AUTO_EVOLVE=true
ZOLANA_AUTO_BREED=true
ZOLANA_AUTO_GACHA=true
ZOLANA_AUTO_PVP=true
ZOLANA_AUTO_SLOTS=true
ZOLANA_TARGET_PLACED=6
# Evolve keeps this much gold in reserve (also lets the d_gold "hold 30k" daily
# quest stay claimable for +150 acct XP); evolve spends only the surplus above it.
ZOLANA_EVOLVE_GOLD_RESERVE=30000
ZOLANA_EVOLVE_CYCLE_BUDGET=60000
# Gacha (gems-only, never touches $ZOLANA token): tier standard=8 / deluxe=15 gems.
ZOLANA_GACHA_TIER=deluxe
ZOLANA_GACHA_KEEP_GEMS=20
ZOLANA_SLOT_BUY_GOLD_FLOOR=50000
# Auto-buy growth eggs with GOLD (bootstrap + reserve). Toggle off live via
# /toggle buyegg (or the 'BuyEgg' panel button) to let gold accumulate — a 50k forest
# egg on every reserve top-up can otherwise keep gold from piling up.
ZOLANA_AUTO_BUY_EGG=true
ZOLANA_EGG_RESERVE_TARGET=2
ZOLANA_EGG_BUY_GOLD_FLOOR=35000
ZOLANA_EGG_BUY_GOLD_RESERVE=30000
ZOLANA_TELEGRAM_BOT_TOKEN=
ZOLANA_TELEGRAM_CHAT_ID=
ZOLANA_TELEGRAM_POLL=true
LOG_LEVEL=info

# --- Anti-ban / robustness ---
ZOLANA_LOOP_JITTER_MS=45000
ZOLANA_ACTION_JITTER_MS=1200
ZOLANA_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36
ZOLANA_HTTP_TIMEOUT_MS=25000
ZOLANA_HTTP_RETRIES=3
ZOLANA_HTTP_BACKOFF_MS=1500
ZOLANA_2CAPTCHA_KEY=
