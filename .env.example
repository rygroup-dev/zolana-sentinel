ZOLANA_REAL_RUN=false
ZOLANA_LOOP_MS=180000
ZOLANA_MIN_ACTION_GAP_MS=1500
ZOLANA_MAX_ACTIONS_PER_CYCLE=12
ZOLANA_LOGIN_MESSAGE_TEMPLATE=auto
